        {"type": "contains", "text": "§16 Sources"},
        {"type": "contains", "text": "ImportYeti"},
        {"type": "contains", "text": "Meta Ad Library"},
        {"type": "contains_regex", "pattern": "CM[123]|contribution margin"},
        {"type": "contains_regex", "pattern": "change my mind"},
        {"type": "min_sources", "count": 5, "location": "§16"},
